@{
    ViewData["Title"] = "Customers";
}

<h2>Customers</h2>

<a href="/Customers/Create" class="btn btn-primary mb-3">Create New Customer</a>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>First Name</th>
            <th>Last Name</th>
            <th>Email</th>
            <th>Phone</th>
            <th></th>
        </tr>
    </thead>
    <tbody id="customersBody"></tbody>
</table>

<script src="~/js/api.js"></script>

<script>
    async function loadCustomers() {
        const response = await apiFetch("/api/customers");
        if (!response) return;

        if (!response.ok) {
            alert("Failed to load customers.");
            return;
        }

        const customers = await response.json();
        const body = document.getElementById("customersBody");
        body.innerHTML = "";

        customers.forEach(c => {
            body.innerHTML += `
                <tr>
                    <td>${c.firstName}</td>
                    <td>${c.lastName}</td>
                    <td>${c.email}</td>
                    <td>${c.phone ?? ""}</td>
                    <td>
                        <a href="/Customers/Edit/${c.id}" class="btn btn-sm btn-warning">Edit</a>
                        <button onclick="deleteCustomer('${c.id}')" class="btn btn-sm btn-danger">Delete</button>
                    </td>
                </tr>
            `;
        });
    }

    async function deleteCustomer(id) {
        if (!confirm("Are you sure you want to delete this customer?"))
            return;

        const response = await apiFetch(`/api/customers/${id}`, { method: "DELETE" });
        if (!response) return;

        if (response.ok) {
            loadCustomers();
        } else {
            alert("Delete failed.");
        }
    }

    loadCustomers();
</script>